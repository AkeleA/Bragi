# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Email magic-link auth for NextAuth
# In local development, missing SMTP values will print the sign-in link in the dev server console.
# For production, use a real SMTP provider such as Resend, Postmark, SendGrid, Mailgun, or Mailtrap.
MAILTRAP_API_TOKEN=
EMAIL_SERVER=
EMAIL_FROM=

# Database/Auth - server-side values for NextAuth/Supabase adapter
# SUPABASE_URL can be the same URL as NEXT_PUBLIC_SUPABASE_URL, but it is read on the server.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Object storage - planned for Cloudflare R2/S3 compatible storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Queue/scheduler - planned for Upstash QStash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Social OAuth/API credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=

# Optional encryption key for social refresh tokens at rest
TOKEN_ENCRYPTION_KEY=
